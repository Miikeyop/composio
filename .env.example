# Primary LLM provider for the optional LLM-assisted research pass.
# Create your key in the ZenMux dashboard.
ZENMUX_API_KEY=replace_with_your_zenmux_key
ZENMUX_MODEL=x-ai/grok-4.5-free
ZENMUX_BASE_URL=https://zenmux.ai/api/v1

# Fallback LLM provider if ZenMux fails or runs out of quota.
# Create your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=replace_with_your_openrouter_key
OPENROUTER_MODEL=tencent/hy3:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_PROVIDER_ORDER=zenmux,openrouter

# Browser Use Cloud SDK for browser-based verification tasks.
# Create your key at https://cloud.browser-use.com/settings
BROWSER_USE_API_KEY=replace_with_your_browser_use_key
BROWSER_USE_MODEL=gpt-5.4-mini

# Optional. Only needed if you later wire the research fetch/search tools
# through Composio MCP/tooling.
COMPOSIO_API_KEY=

# Optional placeholder. Not used by the current scripts.
# Add these only if you implement a Cerebras provider adapter later.
CEREBRAS_API_KEY=
CEREBRAS_MODEL=
